# Apollo.io Session-Based Authentication
# Use your Apollo.io account email and password for authentication
# These will be used to create a session and search for prospects
APOLLO_EMAIL=your-email@example.com
APOLLO_PASSWORD=your-apollo-password

# Hunter.io API Key (Optional)
# Used as fallback if Apollo.io search fails
# Get your key from: https://hunter.io/account
HUNTER_API_KEY=hnt_your_api_key_here

# OpenAI API Key (Optional)
# Used for AI-powered email generation
# Get your key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your_key_here

# Google Gemini API Key (Optional)
# Used as fallback if OpenAI is unavailable
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza_your_key_here

# Gmail OAuth - Google Refresh Token
# One-time setup using scripts/get-refresh-token.js
# This token allows the app to send emails on your behalf
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Gmail OAuth - Google OAuth Client Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Demo Mode
# Set to true to use sample data without making real API calls
DEMO_MODE=true
