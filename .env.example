# ────────────────────────────────────────────────────────────────
# ReachOut Environment Variables
# Copy this to .env.local and fill in your values.
# Add ALL these to your Vercel project → Settings → Environment Variables
# ────────────────────────────────────────────────────────────────

# ── Base URL (required for correct OAuth redirect URIs on Vercel) ──
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Gmail OAuth (required for sending emails) ─────────────────────
# 1. console.cloud.google.com → create project → enable Gmail API
# 2. Create OAuth 2.0 Web app credentials
# 3. Add <NEXT_PUBLIC_BASE_URL>/api/auth/gmail?action=callback as redirect URI
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── Google Gemini (required for AI email generation) ──────────────
# Get from: https://aistudio.google.com/app/apikey
# Used by: Compose (AI emails), Manual Send (domain / JD modes)
GOOGLE_GENERATIVE_AI_API_KEY=AIza_your_gemini_key
GOOGLE_API_KEY=AIza_your_gemini_key   # same key, both names used by @ai-sdk/google

# ── Apollo.io (required for prospect search) ──────────────────────
# Get from: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=api_key_your_apollo_key

# ── Hunter.io (optional — email finder fallback) ──────────────────
# Get from: https://hunter.io/api-keys
HUNTER_API_KEY=hnt_your_key

# ── ContactOut (optional — email finder fallback) ─────────────────
# Get from: https://contactout.com/api
CONTACTOUT_API_KEY=co_your_key
